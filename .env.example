# ── FRC API Credentials (server-side only, never sent to browser) ──
# Get yours at: https://frc-events.firstinspires.org/services/API
FRC_USERNAME=your_username_here
FRC_API_KEY=your_api_key_here

# ── Test Mode ──────────────────────────────────────────────────────
# Set to true to show the Test Mode panel in the dashboard.
# Set to false (or omit) to hide it in production.
TEST_MODE_ENABLED=false

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
